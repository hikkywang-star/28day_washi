<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>小狸日語 · 職人中控台 v13.0</title>
<link rel="apple-touch-icon" sizes="180x180" href="./apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="./favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="./favicon-16x16.png">
<link rel="manifest" href="./site.webmanifest">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700;900&family=Shippori+Mincho:wght@400;700;800&family=Zen+Kaku+Gothic+New:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --kori-bg: #FAF7F2; --kori-text: #1A1410; --kori-gold: #C9A84C;
            --theme-sakura: #E597B2; --theme-matcha: #4A7C6E;
            --theme-hydrangea: #5D78AB; --theme-shu: #B5351A;
            --night: #1A1410; --blue: #B5351A; --card-ex-size: 24px;
            --topbar-h: 70px; --sidebar-w: 420px;
        }

        body, html { margin: 0; padding: 0; height: 100%; font-family: "Zen Kaku Gothic New", sans-serif; background: #F5F0E8; overflow: hidden; }

        /* ══ 原生 RUBY ══ */
        ruby { ruby-position: over; }
        rt { font-size: 0.42em; font-weight: 900; color: var(--kori-primary); font-family: "Zen Kaku Gothic New", sans-serif; letter-spacing: 0; }

        /* ══ TOPBAR ══ */
        .topbar { height: var(--topbar-h); background: var(--night); color: white; display: flex; align-items: center; padding: 0 20px; gap: 10px; border-bottom: 2px solid var(--blue); z-index: 1000; position: relative; flex-wrap: nowrap; overflow: hidden; }
        .brand { font-family: "Shippori Mincho", serif; font-weight: 800; font-size: 14px; white-space: nowrap; }
        .api-zone { display: flex; align-items: center; gap: 6px; background: #222; padding: 5px 10px; border-radius: 6px; flex-shrink: 0; }
        .api-input { background: transparent; border: none; color: #6EE7B7; font-size: 11px; width: 140px; outline: none; font-family: monospace; }
        .api-saved-dot { width: 7px; height: 7px; border-radius: 50%; background: #6EE7B7; flex-shrink: 0; display: none; }

        .ext-group { display: flex; gap: 8px; margin: 0 10px; border-right: 1px solid #444; padding-right: 10px; flex-shrink: 0; }
        .ext-link { color: #ccc; text-decoration: none; font-size: 12px; font-weight: 700; display: flex; align-items: center; gap: 5px; padding: 6px 10px; border-radius: 4px; background: #333; white-space: nowrap; }
        .ext-link:hover { background: #444; color: white; }

        .ctrl-group { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.05); padding: 5px 12px; border-radius: 20px; flex-shrink: 0; }
        .sound-toggle { display: flex; align-items: center; gap: 8px; font-size: 11px; cursor: pointer; color: #9A8E83; white-space: nowrap; user-select: none; }
        .toggle-switch { width: 30px; height: 16px; background: #444; border-radius: 8px; position: relative; transition: 0.3s; flex-shrink: 0; }
        .toggle-switch::after { content: ""; position: absolute; width: 12px; height: 12px; background: white; border-radius: 50%; top: 2px; left: 2px; transition: 0.3s; }
        .sound-active .toggle-switch { background: var(--blue); }
        .sound-active .toggle-switch::after { left: 16px; }

        /* ══ IG CARD ══ */
        .ig-card { width: 380px; height: 380px; position: relative; overflow: hidden; display: flex; flex-direction: column; font-family: "Shippori Mincho", serif; background: var(--kori-card-bg, #FAF7F2); transition: background 0.4s; flex-shrink: 0; }
        .ig-card::after { content: ""; position: absolute; inset: 12px; border: 1px solid var(--kori-gold); opacity: 0.3; pointer-events: none; }
        .card-pattern { position: absolute; inset: 0; z-index: 1; pointer-events: none; background-color: transparent; }
        .card-header { padding: 22px 25px 5px; display: flex; justify-content: space-between; z-index: 10; position: relative; }
        .header-badge { background: var(--kori-primary); color: white; font-size: 11px; padding: 4px 12px; box-shadow: 2px 2px 0 var(--kori-gold); }
        .cover-body { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 0 35px; z-index: 10; text-align: center; position: relative; }
        .cover-desc { font-size: 18px; color: var(--kori-primary); font-weight: 700; background: white; padding: 6px 20px; border: 1px solid var(--kori-primary); border-radius: 4px; }
        .example-box { background: rgba(255,255,255,0.8); padding: 18px; border-left: 6px solid var(--kori-primary); text-align: left; width: 100%; box-sizing: border-box; }
        ruby { ruby-position: over; }
        ruby rt { font-size: 14px; font-weight: 700; color: var(--kori-primary, #B5351A); letter-spacing: 0.02em; font-family: "Zen Kaku Gothic New", sans-serif; }
        .cover-title ruby rt { font-size: 20px; }
        .rt-sized ruby rt { font-size: var(--rt-px, 14px); }
        .cover-title { font-size: 44px; color: var(--kori-card-text, #1A1410); font-weight: 900; margin-bottom: 15px; line-height: 2.2; }
        /* ══ THEME ══ */
        body.theme-sakura    { --kori-primary:#C0607A; --kori-card-bg:#FDF0F4; --kori-card-text:#2A1018; --kori-gold:#D4A0B0; }
        body.theme-matcha    { --kori-primary:#3A7055; --kori-card-bg:#EEF8F2; --kori-card-text:#0F2218; --kori-gold:#8AC4A0; }
        body.theme-hydrangea { --kori-primary:#4860A8; --kori-card-bg:#EFF2FF; --kori-card-text:#10183A; --kori-gold:#9AAADE; }
        body.theme-shu       { --kori-primary:#B5351A; --kori-card-bg:#FAF7F2; --kori-card-text:#1A1410; --kori-gold:#C9A84C; }

        /* ══ LAYOUT ══ */
        .app-container { display: flex; height: calc(100vh - var(--topbar-h)); }
        .left-col { flex: 1; overflow-y: auto; padding: 30px; display: flex; flex-direction: column; align-items: center; gap: 30px; scroll-behavior: smooth; transition: 0.4s ease; }
        .left-col.collapsed { flex: 0 0 0; padding: 0; opacity: 0; pointer-events: none; overflow: hidden; }
        .right-col { width: var(--sidebar-w); background: #1E2F50; border-left: 2px solid var(--blue); display: flex; flex-direction: column; position: relative; transition: 0.4s ease; flex-shrink: 0; }
        .collapse-handle { position: absolute; left: -12px; top: 50%; transform: translateY(-50%); width: 24px; height: 50px; background: var(--blue); color: white; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 100; border-radius: 5px 0 0 5px; }

        /* ══ SNS SIDEBAR ══ */
        .sidebar-inner { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 12px; color: white; overflow: hidden; }
        .sidebar-toolbar { display: flex; gap: 5px; flex-wrap: wrap; }
        .tb-btn { background: rgba(255,255,255,0.1); color: #93C5FD; border: 1px solid rgba(255,255,255,0.15); padding: 5px 10px; border-radius: 4px; cursor: pointer; font-size: 12px; font-weight: 700; font-family: inherit; transition: all .15s; }
        .tb-btn:hover { background: rgba(255,255,255,0.2); color: white; }
        #sideInput { flex: 1; background: #0B1120; color: white; padding: 15px; border-radius: 10px; border: 1px solid #3B82F6; resize: none; outline: none; font-size: 15px; line-height: 1.8; font-family: "Zen Kaku Gothic New", sans-serif; min-height: 0; }

        /* ══ FULLSCREEN EDITOR ══ */
        #fsEditorOverlay { position: fixed; inset: 0; background: #F0F5FF; z-index: 2000; display: none; flex-direction: column; align-items: stretch; padding: 0; overflow: hidden; }
        .fs-card { flex: 1; display: flex; flex-direction: column; background: white; overflow: hidden; }
        .fs-header { padding: 20px 30px; border-bottom: 1.5px solid #DBEAFE; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
        .fs-body { padding: 16px 30px 20px; display: flex; flex-direction: column; gap: 10px; flex: 1; overflow: hidden; }
        .fs-toolbar { display: flex; gap: 6px; flex-wrap: wrap; }
        .fs-tb-btn { background: #F4F7FF; color: #2563EB; border: 1px solid #DBEAFE; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 700; font-family: inherit; transition: all .15s; }
        .fs-tb-btn:hover { background: #DBEAFE; }
        #fsInput { width: 100%; flex: 1; min-height: 0; padding: 18px; border: 2px solid #DBEAFE; border-radius: 16px; font-size: 17px; line-height: 1.9; resize: none; outline: none; font-family: "Zen Kaku Gothic New", sans-serif; box-sizing: border-box; transition: border-color .2s; }
        #fsInput:focus { border-color: #3B82F6; }
        .fs-char-counter { font-size: 12px; color: #9CA3AF; text-align: right; }
        .fs-char-counter.warn { color: #F59E0B; }
        .fs-char-counter.over { color: #EF4444; }

        /* ══ AI PROGRESS ══ */
        .ai-progress-bar { height: 4px; background: #ddd; border-radius: 99px; overflow: hidden; display: none; }
        .ai-progress-fill { height: 100%; width: 0%; background: linear-gradient(90deg, #B5351A, #E57348); border-radius: 99px; transition: width .5s ease; }

        /* ══ TOAST ══ */
        #toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px); background: #1A1410; color: white; padding: 10px 22px; border-radius: 99px; font-size: 13px; font-weight: 700; opacity: 0; pointer-events: none; transition: all .3s; z-index: 9999; border: 1px solid var(--blue); white-space: nowrap; }
        #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

        /* ══ EMOJI ══ */
        .emoji-panel { background: #0B1120; border: 1px solid #3B82F6; border-radius: 8px; padding: 8px; display: none; flex-wrap: wrap; gap: 2px; flex-shrink: 0; }
        .emoji-panel.open { display: flex; }
        .e-btn { font-size: 18px; background: none; border: none; cursor: pointer; padding: 3px 5px; border-radius: 4px; transition: background .15s; line-height: 1; }
        .e-btn:hover { background: rgba(255,255,255,.15); transform: scale(1.2); }
        .fs-emoji-panel { background: #F4F7FF; border: 1px solid #DBEAFE; border-radius: 8px; padding: 8px; display: none; flex-wrap: wrap; gap: 2px; flex-shrink: 0; max-height: 100px; overflow-y: auto; }
        .fs-emoji-panel.open { display: flex; }
        .fs-e-btn { font-size: 20px; background: none; border: none; cursor: pointer; padding: 3px 5px; border-radius: 4px; transition: background .15s; line-height: 1; }
        .fs-e-btn:hover { background: #DBEAFE; transform: scale(1.15); }

        /* ══ MISC ══ */
        .btn-primary { background: var(--blue); color: white; padding: 10px 20px; border-radius: 5px; border: none; cursor: pointer; font-weight: bold; font-family: inherit; transition: all .18s; }
        .btn-primary:hover { filter: brightness(1.1); }
        .btn-primary:active { transform: scale(.97); }
        #offscreen-render-zone { position: fixed; top: -9999px; left: -9999px; z-index: -999; pointer-events: none; }

        /* ══ PATTERN PICKER ══ */
        .pat-picker { display:flex; gap:5px; align-items:center; flex-shrink:0; }
        .pat-swatch { width:24px; height:24px; border-radius:4px; border:2px solid transparent; cursor:pointer; overflow:hidden; flex-shrink:0; transition:all .2s; }
        .pat-swatch.active { border-color:#fff; transform:scale(1.2); }
        .pat-swatch:hover { border-color:rgba(255,255,255,.6); }

        /* ══ CARD EDITOR OVERLAY ══ */
        #cardEditorOverlay { position:fixed; inset:0; background:rgba(10,10,20,.75); z-index:3000; display:none; align-items:center; justify-content:center; backdrop-filter:blur(4px); }
        #cardEditorOverlay.open { display:flex; }
        .ce-modal { width:min(960px,96vw); max-height:90vh; background:#FAFAFA; border-radius:20px; overflow:hidden; display:flex; flex-direction:column; box-shadow:0 32px 80px rgba(0,0,0,.4); }
        .ce-topbar { background:#1A1410; color:white; padding:14px 22px; display:flex; align-items:center; gap:14px; flex-shrink:0; }
        .ce-title { font-family:"Shippori Mincho",serif; font-size:16px; font-weight:800; letter-spacing:.08em; flex:1; }
        .ce-tabs { display:flex; gap:2px; background:#111; border-radius:8px; padding:3px; flex-shrink:0; }
        .ce-tab { padding:6px 14px; border-radius:6px; cursor:pointer; font-size:12px; font-weight:700; color:#9A8E83; border:none; background:none; font-family:inherit; transition:all .18s; white-space:nowrap; }
        .ce-tab.active { background:var(--ce-accent,#B5351A); color:white; }
        .ce-body { display:flex; flex:1; min-height:0; overflow:hidden; }
        .ce-preview-col { width:390px; flex-shrink:0; background:#E8E4DC; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:12px; padding:20px; }
        .ce-preview-label { font-size:11px; color:#666; font-weight:700; letter-spacing:.1em; }
        .ce-edit-col { flex:1; overflow-y:auto; padding:20px 24px; display:flex; flex-direction:column; gap:14px; }
        .ce-field { display:flex; flex-direction:column; gap:5px; }
        .ce-label { font-size:11px; font-weight:800; color:#666; letter-spacing:.06em; text-transform:uppercase; }
        .ce-input { border:1.5px solid #DDD; border-radius:8px; padding:10px 12px; font-size:14px; font-family:inherit; outline:none; transition:border-color .18s; resize:none; line-height:1.7; }
        .ce-input:focus { border-color:#B5351A; }
        .ce-hint { font-size:10px; color:#9CA3AF; }
        .ce-footer { padding:14px 22px; border-top:1px solid #E5E7EB; display:flex; gap:10px; justify-content:flex-end; background:#FAFAFA; flex-shrink:0; }
    </style>
</head>
<body class="theme-shu">

<header class="topbar">
    <div class="brand">🐾 小狸日語 v13.0</div>

    <div class="ext-group">
        <a href="https://docs.google.com/spreadsheets/d/1Ym-ELnrYKV-MgYOJWDf1_TMYWH6Aw4ynsAYgbLxG4Ic/edit" target="_blank" class="ext-link"><i class="fas fa-table"></i> 煉金爐</a>
        <a href="https://docs.google.com/document/d/1KThVRf13zDM7FYRPteOPijcB9_xp6WAUCDFy9ATuJsw/edit" target="_blank" class="ext-link"><i class="fas fa-file-alt"></i> 書稿</a>
    </div>

    <!-- ✅ FIX: API Key 欄位自動讀取儲存值，存為 kori_google_key -->
    <div class="api-zone">
        <div class="api-saved-dot" id="apiDot" title="Key 已儲存"></div>
        <input type="password" id="apiKeyInput" class="api-input" placeholder="Google Gemini Key" autocomplete="off">
        <button class="btn-primary" style="padding:3px 9px; font-size:10px;" onclick="saveApiKey()">儲存</button>
    </div>

    <div class="ctrl-group">
        <div class="sound-toggle" onclick="toggleSound()" id="soundSwitch">📜 和紙 <div class="toggle-switch"></div></div>
        <button class="btn-primary" style="background:var(--theme-matcha); font-size:12px;" onclick="rotateTheme()">🎨 換主題</button>
        <div class="pat-picker" title="花紋" id="patPicker"></div>
    </div>

    <div style="flex:1; min-width:10px;"></div>

    <span id="saveIndicator" style="font-size:11px;color:#6EE7B7;font-weight:700;white-space:nowrap;opacity:0;transition:opacity .5s;">✅ 已儲存</span>
    <button class="btn-primary" style="white-space:nowrap;font-size:13px;background:#1D4ED8;" onclick="exportBackup()">📦 匯出備份</button>
    <label class="btn-primary" style="white-space:nowrap;font-size:13px;background:#065F46;cursor:pointer;margin:0;">📂 還原備份<input type="file" accept=".json" onchange="importBackup(this)" style="display:none;"></label>
    <button class="btn-primary" style="white-space:nowrap;font-size:13px;background:#2563EB;" onclick="openJsonModal()">📥 導入 JSON</button>
    <button class="btn-primary" style="white-space:nowrap;font-size:13px;background:#7F1D1D;" onclick="hardReset()">🗑 重置</button>
    <input type="text" id="alchemyTopic" style="background:#333; color:white; border:none; padding:8px 10px; border-radius:4px; width:110px; font-size:12px; font-family:inherit;" placeholder="主題方向（選填）" oninput="syncAlchemyTopic(this)">
    <button class="btn-primary" style="white-space:nowrap; font-size:13px;" onclick="generateAlchemy()">⚡ 一鍵煉金</button>
</header>

<!-- ══ JSON 導入 Modal ══ -->
<div id="jsonModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9000;align-items:center;justify-content:center;">
    <div style="background:white;border-radius:16px;width:min(640px,92vw);padding:28px;display:flex;flex-direction:column;gap:16px;box-shadow:0 24px 60px rgba(0,0,0,.4);">
        <div style="display:flex;align-items:center;justify-content:space-between;">
            <div style="font-size:18px;font-weight:900;color:#1A1410;">📥 貼上 28 天 JSON</div>
            <button onclick="closeJsonModal()" style="background:#F1F5F9;border:none;border-radius:8px;padding:6px 14px;font-size:16px;cursor:pointer;font-weight:900;">✕</button>
        </div>
        <textarea id="jsonImportInput" style="width:100%;height:280px;font-family:monospace;font-size:12px;box-sizing:border-box;border:2px solid #2563EB;border-radius:10px;padding:14px;resize:vertical;outline:none;line-height:1.7;" placeholder='貼上 AI 產生的 JSON 陣列：

[
  {
    "d": 1,
    "word_ruby": "<ruby>気<rt>き</rt></ruby>まずい",
    "word_plain": "気まずい",
    "m_s": "尷尬的",
    "m_l": "形容場面令人感到難為情...",
    "e1_jp": "沈黙が気まずい。",
    "e1_zh": "沉默很尷尬。",
    "e2_jp": "目が合って気まずくなった。",
    "e2_zh": "四目相對後變得很尷尬。"
  },
  { "d": 2, ... }
]'></textarea>
        <div class="ai-progress-bar" id="importProgress" style="display:none;"><div class="ai-progress-fill" id="importFill"></div></div>
        <button class="btn-primary" onclick="importJson()" style="width:100%;padding:14px;font-size:15px;background:#2563EB;">✅ 確認導入</button>
    </div>
</div>

<div class="app-container">
    <!-- LEFT: Day Feed -->
    <div class="left-col" id="leftCol" onscroll="handleScroll()">
        <!-- ══ 智慧導入專區 ══ -->
        <div style="width:100%;max-width:800px;background:white;border-radius:14px;border:2px solid #B5351A;overflow:hidden;box-shadow:0 4px 18px rgba(0,0,0,.08);">

            <div style="background:#1A1410;padding:14px 20px;display:flex;align-items:center;gap:12px;">
                <span style="color:#C9A84C;font-weight:800;font-size:15px;">🧪 智慧導入專區</span>
                <span style="flex:1;"></span>
                <button id="resetBtn" style="background:#7F1D1D;color:#FCA5A5;border:1px solid #991B1B;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:900;cursor:pointer;font-family:inherit;">🗑 清除全部資料</button>
            </div>

            <div style="padding:20px;display:flex;flex-direction:column;gap:16px;">

                <!-- JSON 輸入 -->
                <div>
                    <div style="font-size:13px;font-weight:900;color:#B5351A;margin-bottom:8px;">📥 貼上 28 天 JSON</div>
                    <textarea id="jsonImportInput" style="width:100%;height:200px;font-family:monospace;font-size:12px;box-sizing:border-box;border:2px solid #B5351A;border-radius:10px;padding:14px;resize:vertical;outline:none;line-height:1.7;background:#FAFAF8;"></textarea>
                </div>

                <div class="ai-progress-bar" id="importProgress"><div class="ai-progress-fill" id="importFill"></div></div>
                <button class="btn-primary" style="width:100%;padding:14px;font-size:15px;" onclick="importJson()">✅ 導入 JSON</button>

                <hr style="border:none;border-top:1px solid #eee;margin:4px 0;">

                <!-- TSV 輸入 -->
                <div>
                    <div style="font-size:13px;font-weight:900;color:#555;margin-bottom:8px;">📊 Google Sheet TSV 導入</div>
                    <textarea id="tsvInput" style="width:100%;height:80px;font-family:monospace;font-size:12px;box-sizing:border-box;border:1.5px solid #DDD;border-radius:8px;padding:10px;resize:vertical;outline:none;" placeholder="1&#9;&lt;ruby&gt;…&lt;/ruby&gt;&#9;待つ&#9;…"></textarea>
                    <button class="btn-primary" style="width:100%;margin-top:8px;padding:11px;" onclick="importTsv()">確認導入 TSV 🧪</button>
                </div>

                <hr style="border:none;border-top:1px solid #eee;margin:4px 0;">

                <!-- Prompt + Gemini -->
                <div style="display:flex;gap:8px;align-items:center;">
                    <input id="alchemyTopicPanel" style="flex:1;background:#F8F5F0;border:1px solid #DDD;border-radius:6px;padding:8px 10px;font-size:12px;font-family:inherit;outline:none;" placeholder="主題方向（選填）">
                    <button class="btn-primary" style="white-space:nowrap;font-size:12px;" onclick="copyAlchemyPrompt()">📋 複製 Prompt</button>
                    <input id="alchemyTopic2" style="display:none;">
                    <button class="btn-primary" style="white-space:nowrap;font-size:12px;background:#4A7C6E;" onclick="generateAlchemy()">⚡ Gemini 生成</button>
                </div>

            </div>
        </div>
        <div id="dayFeed" style="width:100%; display:flex; flex-direction:column; align-items:center; gap:40px;"></div>
    </div>

    <!-- RIGHT: SNS Editor -->
    <aside class="right-col" id="sidebar">
        <div class="collapse-handle" onclick="toggleLeftCol()">
            <i class="fas fa-chevron-left" id="colIcon"></i>
        </div>
        <div class="sidebar-inner">
            <div style="display:flex; justify-content:space-between; align-items:center; flex-shrink:0;">
                <h3 style="margin:0; font-size:15px;">✦ SNS 快速編輯</h3>
