        const fi = s.indexOf('['), li = s.lastIndexOf(']');
        if (fi !== -1 && li > fi) s = s.slice(fi, li+1);
        parsed = JSON.parse(s);
        if (!Array.isArray(parsed)) throw new Error('頂層應為 JSON 陣列 [...]');
    } catch(e) {
        bar.style.width = '0%'; barWrap.style.display = 'none';
        showToast('❌ JSON 解析失敗：' + e.message);
        return;
    }

    setTimeout(() => { bar.style.width = '100%'; }, 100);

    let count = 0, skipped = 0;
    parsed.forEach(item => {
        const day = Number(item.d || item.day);
        if (!day || day < 1 || day > 28) { skipped++; return; }
        const idx = monthData.findIndex(x => x.d === day);
        if (idx === -1) { skipped++; return; }
        monthData[idx] = {
            ...monthData[idx],
            word_ruby:  item.word_ruby  || monthData[idx].word_ruby,
            word_plain: item.word_plain || monthData[idx].word_plain,
            o:          item.o          || '',
            m_s:        item.m_s        || monthData[idx].m_s,
            m_l:        item.m_l        || monthData[idx].m_l,
            e1_jp:      item.e1_jp      || monthData[idx].e1_jp,
            e1_zh:      item.e1_zh      || monthData[idx].e1_zh,
            e2_jp:      item.e2_jp      || monthData[idx].e2_jp,
            e2_zh:      item.e2_zh      || monthData[idx].e2_zh,
            cat:        item.cat        || '',
            keys:       item.keys       || '',
        };
        count++;
    });

    persist(); renderFeed();
    setTimeout(() => { barWrap.style.display = 'none'; bar.style.width = '0%'; }, 800);
    document.getElementById('jsonImportInput').value = '';
    closeJsonModal();
    showToast(`🎉 導入完成！${count} 天${skipped ? `（跳過 ${skipped}）` : ''}`);
}


async function generateAlchemy() {
    const key = loadApiKey();
    if (!key) { showToast('⚠ 請先填入並儲存 Gemini Key'); document.getElementById('apiKeyInput').focus(); return; }
    const topic = document.getElementById('alchemyTopic').value.trim();
    const btn = document.querySelector('button[onclick="generateAlchemy()"]');
    const orig = btn.innerHTML; btn.innerHTML = '⏳ 生成中…'; btn.disabled = true;

    const topicLine = topic ? `本月主題方向：【${topic}】，請圍繞此方向選詞。` : '請自由選擇對台灣日語學習者最有幫助的詞彙。';
    const prompt = `你是日語教學專家，協助台灣教師小狸製作 SNS 教學內容。${topicLine}
請以 JSON 陣列輸出 28 天教學內容，只輸出純 JSON，不含說明文字或 markdown。
格式：[{"d":1,"word_ruby":"<ruby>気<rt>き</rt></ruby>まずい","word_plain":"気まずい","o":"有這種尷尬的場合嗎？","m_s":"尷尬的","m_l":"形容場面或氣氛令人感到不舒服、難為情。","e1_jp":"沈黙が気まずい。","e1_zh":"沉默很尷尬。","e2_jp":"目が合って気まずくなった。","e2_zh":"四目相對後變得很尷尬。","cat":"N3單字","keys":"気まずい,尷尬"}]
請完整輸出所有 28 個物件。`;

    try {
        const geminiModel = localStorage.getItem('kori_gemini_model') || 'gemini-2.5-flash-preview-04-17';
        const url = `https://generativelanguage.googleapis.com/v1beta/models/${geminiModel}:generateContent?key=${key}`;
        const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ contents:[{parts:[{text:prompt}]}], generationConfig:{maxOutputTokens:8192,temperature:0.9} })
        });
        if (!res.ok) {
            const e = await res.json().catch(()=>({}));
            throw new Error(e.error?.message || `HTTP ${res.status}`);
        }
        const j = await res.json();
        const text = j.candidates?.[0]?.content?.parts?.map(p=>p.text||'').join('') || '';
        let s = text.replace(/```json\s*/gi,'').replace(/```\s*/g,'').trim();
        const fi = s.indexOf('['), li = s.lastIndexOf(']');
        if (fi !== -1 && li > fi) s = s.slice(fi, li+1);
        const parsed = JSON.parse(s);
        if (!Array.isArray(parsed)) throw new Error('回應格式錯誤');
        parsed.forEach(item => {
            const idx = monthData.findIndex(d => d.d === item.d);
            if (idx !== -1) monthData[idx] = { ...monthData[idx], ...item, editedText: '' };
        });
        persist(); renderFeed();
        showToast(`🎉 AI 生成完成！${parsed.length} 天內容已更新`);
    } catch(e) {
        showToast('❌ 生成失敗：' + e.message);
        console.error(e);
    } finally {
        btn.innerHTML = orig; btn.disabled = false;
    }
}

