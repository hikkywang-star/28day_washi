/* ═══════════════════════════════════════════
   RUBY 解析
═══════════════════════════════════════════ */
function isPureKana(s) {
    // true if every char is hiragana, katakana, prolonged sound mark, or small kana
    return /^[ぁ-んァ-ヴーｦ-ﾟ・。、]+$/.test(s.replace(/\s/g,''));
}
function parseRuby(text) {
    if (!text) return '';
    return text.replace(/<ruby>(.*?)<rt>(.*?)<\/rt><\/ruby>/g, (_, kanji, kana) => {
        // strip any inner tags to get plain base text
        const base = kanji.replace(/<[^>]+>/g,'');
        if (isPureKana(base)) {
            // pure kana: render base only, no ruby annotation
            return `<span class="ruby-base">${kanji}</span>`;
        }
        return `<ruby>${kanji}<rt>${kana}</rt></ruby>`;
    });
}

function sideWrapCode() { sideWrap('`','`'); }
function fsWrapCode()   { fsWrap('`','`'); }
function stripRuby(text) {
    if (!text) return '';
    return text.replace(/<ruby>(.*?)<rt>.*?<\/rt><\/ruby>/g, '$1').replace(/<[^>]+>/g, '');
}

/* ═══════════════════════════════════════════
   資料系統
═══════════════════════════════════════════ */
const DEFAULT_DAY = i => ({
    d: i+1, word_ruby: '待つ', word_plain: '待つ', o: '', m_s: '（未填）', m_l: '',
    e1_jp: '例句', e1_zh: '翻譯', e2_jp: '例句', e2_zh: '翻譯', cat: '', keys: ''
});
let monthData = (() => {
    try {
        const saved = JSON.parse(localStorage.getItem('kori_data'));
        if (Array.isArray(saved) && saved.length) return saved;
    } catch(e) {}
    return Array.from({length:28}, (_,i) => DEFAULT_DAY(i));
})();

function persist() {
    try {
        localStorage.setItem('kori_data', JSON.stringify(monthData));
        // 顯示儲存指示
        const el = document.getElementById('saveIndicator');
        if (el) {
            const t = new Date();
            const hhmm = t.getHours().toString().padStart(2,'0') + ':' + t.getMinutes().toString().padStart(2,'0');
            el.textContent = '✅ 已儲存 ' + hhmm;
            el.style.opacity = '1';
            clearTimeout(el._hideTimer);
            el._hideTimer = setTimeout(() => { el.style.opacity = '0'; }, 3000);
        }
    } catch(e) {}
}

/* ── 匯出備份 ── */
function exportBackup() {
    const payload = {
        version: 'kori_v15',
        savedAt: new Date().toISOString(),
        monthData,
        snsPrefix: localStorage.getItem('kori_sns_prefix') || '',
        snsSuffix: localStorage.getItem('kori_sns_suffix') || '',
        tabFontSizes,
    };
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    const d = new Date();
    a.download = `小狸日語備份_${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}_${String(d.getHours()).padStart(2,'0')}${String(d.getMinutes()).padStart(2,'0')}.json`;
    a.click();
    showToast('📦 備份已下載！請妥善保存');
}

/* ── 還原備份 ── */
function importBackup(input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const payload = JSON.parse(e.target.result);
            // 相容舊格式（純陣列）或新格式（物件含 version）
            const data = Array.isArray(payload) ? payload : payload.monthData;
            if (!Array.isArray(data)) throw new Error('格式錯誤');
            monthData = data;
            if (payload.snsPrefix !== undefined) localStorage.setItem('kori_sns_prefix', payload.snsPrefix);
            if (payload.snsSuffix !== undefined) localStorage.setItem('kori_sns_suffix', payload.snsSuffix);
            if (payload.tabFontSizes) {
                tabFontSizes = payload.tabFontSizes;
                saveTabSizes();
            }
            persist();
            loadSnsTemplate();
            renderFeed();
            showToast('✅ 備份還原成功！' + data.length + ' 天資料已載入');
        } catch(err) {
            showToast('❌ 還原失敗：' + err.message);
        }
        input.value = ''; // reset so same file can be re-selected
    };
    reader.readAsText(file);
}

