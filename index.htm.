/* ═══════════════════════════════════════════
   ✅ FIX: importTsv — 修正欄位對齊 (col[3]=o)
   格式：d | word_ruby | word_plain | o | m_s | m_l | e1_jp | e1_zh | e2_jp | e2_zh | cat | keys
═══════════════════════════════════════════ */
function importTsv() {
    const raw = document.getElementById('tsvInput').value.trim();
    if (!raw) { showToast('請先貼上資料'); return; }
    const lines = raw.split('\n').filter(l => l.trim());
    // 自動跳過表頭（第一格不是數字）
    const dataLines = isNaN(parseInt(lines[0].split('\t')[0])) ? lines.slice(1) : lines;
    let count = 0, skipped = 0;
    dataLines.forEach(line => {
        const cols = line.split('\t');
        if (cols.length < 3) { skipped++; return; }
        const d = parseInt(cols[0]);
        if (isNaN(d) || d < 1 || d > 28) { skipped++; return; }
        const idx = monthData.findIndex(x => x.d === d);
        if (idx === -1) { skipped++; return; }
        monthData[idx] = {
            ...monthData[idx],
            word_ruby:  cols[1]?.trim() || monthData[idx].word_ruby,
            word_plain: cols[2]?.trim() || monthData[idx].word_plain,
            o:          cols[3]?.trim() || '',
            m_s:        cols[4]?.trim() || monthData[idx].m_s,
            m_l:        cols[5]?.trim() || monthData[idx].m_l,
            e1_jp:      cols[6]?.trim() || monthData[idx].e1_jp,
            e1_zh:      cols[7]?.trim() || monthData[idx].e1_zh,
            e2_jp:      cols[8]?.trim() || monthData[idx].e2_jp,
            e2_zh:      cols[9]?.trim() || monthData[idx].e2_zh,
            cat:        cols[10]?.trim() || '',
            keys:       cols[11]?.trim() || '',
        };
        count++;
    });
    persist();
    renderFeed();
    showToast(`✅ 導入 ${count} 天${skipped ? `（跳過 ${skipped}）` : ''}`);
}

