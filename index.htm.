/* ═══════════════════════════════════════════
   書稿 TSV（Google Sheet 格式）
   欄位：日期 | 章節 | 關鍵字 | 標題 | 摘要 | 全文 | 狀態
═══════════════════════════════════════════ */
function copyBookTsvFs() {
    const text = document.getElementById('fsInput').value.trim();
    if (!text) { showToast('請先輸入內容'); return; }
    const today = new Date().toLocaleDateString('zh-TW',{year:'numeric',month:'2-digit',day:'2-digit'}).replace(/\//g,'-');
    const dayObj = currentEditorDay ? monthData.find(x => x.d === currentEditorDay) : null;
    const chapter  = dayObj?.cat   || '';
    const keywords = dayObj?.keys  || '';
    const title    = dayObj ? `Day${dayObj.d} ${dayObj.word_plain}` : text.split('\n')[0].replace(/^[▍\s【】]+/,'').slice(0,30);
    const summary  = dayObj?.m_s   || text.split('\n').slice(0,2).join(' ').slice(0,60);
    const row = [today, chapter, keywords, title, summary, text, '待審'];
    function tsvCell(s) {
        s = String(s == null ? '' : s);
        if (s.includes('\t') || s.includes('"') || s.includes('\n')) return '"' + s.replace(/"/g,'""') + '"';
        return s;
    }
    const tsv = row.map(tsvCell).join('\t');
    navigator.clipboard.writeText(tsv).then(() => {
        window.open('https://docs.google.com/spreadsheets/d/1Ym-ELnrYKV-MgYOJWDf1_TMYWH6Aw4ynsAYgbLxG4Ic/edit', '_blank');
        showToast('✅ 書稿 TSV 已複製！請貼到 Google Sheet');
    }).catch(() => showToast('複製失敗，請手動複製'));
}

