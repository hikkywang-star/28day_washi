/* ─── Unicode 格式轉換（讓 IG / Threads 顯示粗體/斜體/打字機）───── */
const UNI_BOLD = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';
const UNI_BOLD_MAP = '𝗔𝗕𝗖𝗗𝗘𝗙𝗚𝗛𝗜𝗝𝗞𝗟𝗠𝗡𝗢𝗣𝗤𝗥𝗦𝗧𝗨𝗩𝗪𝗫𝗬𝗭𝗮𝗯𝗰𝗱𝗲𝗳𝗴𝗵𝗶𝗷𝗸𝗹𝗺𝗻𝗼𝗽𝗾𝗿𝘀𝘁𝘂𝘃𝘄𝘅𝘆𝘇𝟬𝟭𝟮𝟯𝟰𝟱𝟲𝟳𝟴𝟵'.split('');
const UNI_ITAL_MAP = '𝘈𝘉𝘊𝘋𝘌𝘍𝘎𝘏𝘐𝘑𝘒𝘓𝘔𝘕𝘖𝘗𝘘𝘙𝘚𝘛𝘜𝘝𝘞𝘟𝘠𝘡𝘢𝘣𝘤𝘥𝘦𝘧𝘨𝘩𝘪𝘫𝘬𝘭𝘮𝘯𝘰𝘱𝘲𝘳𝘴𝘵𝘶𝘷𝘸𝘹𝘺𝘻𝟬𝟭𝟮𝟯𝟰𝟱𝟲𝟳𝟴𝟵'.split('');
const UNI_MONO_MAP = '𝙰𝙱𝙲𝙳𝙴𝙵𝙶𝙷𝙸𝙹𝙺𝙻𝙼𝙽𝙾𝙿𝚀𝚁𝚂𝚃𝚄𝚅𝚆𝚇𝚈𝚉𝚊𝚋𝚌𝚍𝚎𝚏𝚐𝚑𝚒𝚓𝚔𝚕𝚖𝚗𝚘𝚙𝚚𝚛𝚜𝚝𝚞𝚟𝚠𝚡𝚢𝚣𝟶𝟷𝟸𝟹𝟺𝟻𝟼𝟽𝟾𝟿'.split('');

function mapChar(c, map) {
    const i = UNI_BOLD.indexOf(c);
    return i >= 0 ? map[i] : c;
}
function applyUnicode(text) {
    // **bold** → 𝗯𝗼𝗹𝗱
    text = text.replace(/\*\*([^*]+)\*\*/g, (_, s) => s.split('').map(c => mapChar(c, UNI_BOLD_MAP)).join(''));
    // _italic_ → 𝘪𝘵𝘢𝘭𝘪𝘤
    text = text.replace(/_([^_\n]+)_/g, (_, s) => s.split('').map(c => mapChar(c, UNI_ITAL_MAP)).join(''));
    // `mono` → 𝚖𝚘𝚗𝚘
    text = text.replace(/`([^`\n]+)`/g, (_, s) => s.split('').map(c => mapChar(c, UNI_MONO_MAP)).join(''));
    return text;
}

