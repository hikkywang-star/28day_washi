/* ═══════════════════════════════════════════
   ✅ FIX: downloadAllFour — 用 scale 而非 transform
   保持卡片 380px，以 scale=1080/380≈2.842 輸出 1080px
═══════════════════════════════════════════ */
async function downloadAllFour(day, btn) {
    const data = monthData.find(d => d.d === day);
    if (!data) return;
    const orig = btn.innerHTML; btn.innerHTML = '⏳ 生成中…'; btn.disabled = true;

    const zone = document.getElementById('offscreen-render-zone');
    const color = getThemeColor();
    const SCALE = 1080 / 380;

    const layouts = [0,1,2,3].map(ti => ceGetLayoutHTML(data, ti));

    for (let i = 0; i < 4; i++) {
        const { image:pi, size:ps, opacity:po } = buildPatternBg(currentPatternIdx);
        zone.innerHTML = `
            <div class="ig-card" style="--kori-primary:${color};background:${getThemeBg()};color:${getThemeText()};width:380px;height:380px;border-radius:0;">
                <div class="card-pattern" style="background-image:${pi};background-size:${ps};opacity:${po};"></div>
                <div class="card-header">
                    <div style="font-size:11px;font-weight:bold;opacity:.6;">小狸日語</div>
                </div>
                ${layouts[i]}
            </div>`;
        const card = zone.firstElementChild;
        try {
            const canvas = await html2canvas(card, {
                scale: SCALE,           // 380 × 2.842 ≈ 1080px
                useCORS: true,
                backgroundColor: '#FAF7F2',
                logging: false,
                allowTaint: true
            });
            // 確保輸出精確 1080×1080
            const out = document.createElement('canvas');
            out.width = 1080; out.height = 1080;
            const ctx = out.getContext('2d');
            ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high';
            ctx.fillStyle = getThemeBg(); ctx.fillRect(0,0,1080,1080);
            ctx.drawImage(canvas, 0, 0, 1080, 1080);
            const link = document.createElement('a');
            link.download = `小狸日語_${data.word_plain||('Day'+day)}_P${i+1}.jpg`;
            link.href = out.toDataURL('image/jpeg', 0.95);
            link.click();
        } catch(e) { console.error('圖卡', i+1, e); }
        await new Promise(r => setTimeout(r, 500));
    }
    zone.innerHTML = '';
    btn.innerHTML = '✅ 下載完成'; btn.disabled = false;
    setTimeout(() => { btn.innerHTML = orig; }, 2500);
}

